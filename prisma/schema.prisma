generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  display_name String
  avatar_url String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  identities               UserIdentity[]
  sentRequests             Friendship[]             @relation("Requester")
  receivedRequests         Friendship[]             @relation("Receiver")
  notifications            Notification[]
  notificationPreferences  NotificationPreference[]
  notificationJobs         NotificationJob[]
  activities               Activity[]
  activityAvailabilities   ActivityAvailability[]
  sentInvitations          ActivityInvitation[]   @relation("InvitationSent")
  receivedInvitations      ActivityInvitation[]   @relation("InvitationReceived")
  activityParticipants     ActivityParticipant[]
  activityVotes            ActivityVote[]

  @@map("users")
}

model UserIdentity {
  id               String   @id @default(uuid())
  user_id          String
  provider         String
  provider_user_id String?
  email            String?
  password_hash    String?
  created_at       DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, provider])
  @@unique([provider, provider_user_id])
  @@map("user_identities")
}

model Friendship {
  id           String   @id @default(uuid())
  requester_id String
  receiver_id  String
  status       String   @default("pending")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  requester User @relation("Requester", fields: [requester_id], references: [id], onDelete: Cascade)
  receiver  User @relation("Receiver", fields: [receiver_id], references: [id], onDelete: Cascade)

  @@unique([requester_id, receiver_id])
  @@map("friendships")
}

model Notification {
  id             String   @id @default(uuid())
  user_id        String
  type           String
  reference_id   String?
  reference_type String?
  is_read        Boolean  @default(false)
  created_at     DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum ActivityStatus {
  draft
  recruiting
  voting
  tiebreaking
  confirmed
  cancelled
}

model Activity {
  id               String         @id @default(uuid())
  creator_id       String
  title            String
  description      String?       
  location         String?
  max_participants Int?
  cover_image_url  String?
  status           ActivityStatus @default(draft)
  pre_notify_hours Int            @default(24)
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt

  creator                User                   @relation(fields: [creator_id], references: [id], onDelete: Cascade)
  notificationJobs       NotificationJob[]
  schedule               ActivitySchedule?
  availabilities         ActivityAvailability[]
  invitations            ActivityInvitation[]
  participants           ActivityParticipant[]
  votes                  ActivityVote[]
  chat                   ActivityChat?

  @@map("activities")
}

model ActivityChat {
  id          String   @id @default(uuid())
  activity_id String   @unique
  name        String
  created_at  DateTime @default(now())

  activity Activity @relation(fields: [activity_id], references: [id], onDelete: Cascade)

  @@map("activity_chats")
}

model ActivityVote {
  id          String   @id @default(uuid())
  activity_id String
  user_id     String
  slot_start  DateTime
  slot_end    DateTime
  created_at  DateTime @default(now())

  activity Activity @relation(fields: [activity_id], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([activity_id, user_id])
  @@map("activity_votes")
}

enum ActivityParticipantStatus {
  joined
  left
  removed
}

model ActivityParticipant {
  id          String                    @id @default(uuid())
  activity_id String
  user_id     String
  status      ActivityParticipantStatus @default(joined)
  joined_at   DateTime                  @default(now())

  activity Activity @relation(fields: [activity_id], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([activity_id, user_id])
  @@map("activity_participants")
}

enum ActivityInvitationStatus {
  pending
  accepted
  declined
}

model ActivityInvitation {
  id           String                   @id @default(uuid())
  activity_id  String
  inviter_id   String
  invitee_id   String
  invite_token String?                  @unique
  status       ActivityInvitationStatus @default(pending)
  created_at   DateTime                 @default(now())

  activity Activity @relation(fields: [activity_id], references: [id], onDelete: Cascade)
  inviter  User     @relation("InvitationSent", fields: [inviter_id], references: [id], onDelete: Cascade)
  invitee  User     @relation("InvitationReceived", fields: [invitee_id], references: [id], onDelete: Cascade)

  @@map("activity_invitations")
}

model ActivityAvailability {
  id          String   @id @default(uuid())
  activity_id String
  user_id     String
  slot_start  DateTime
  slot_end    DateTime
  created_at  DateTime @default(now())

  activity Activity @relation(fields: [activity_id], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([activity_id, user_id, slot_start])
  @@map("activity_availabilities")
}

enum ActivityScheduleType {
  slot
  range
}

model ActivitySchedule {
  id                String               @id @default(uuid())
  activity_id       String               @unique
  schedule_type     ActivityScheduleType
  window_start      DateTime             @db.Date
  window_end        DateTime             @db.Date
  slot_duration_min Int?                 @default(60)
  deadline_at       DateTime?
  is_all_day        Boolean              @default(false)
  vote_deadline_at  DateTime?            
  confirmed_start   DateTime?
  confirmed_end     DateTime?

  activity Activity @relation(fields: [activity_id], references: [id], onDelete: Cascade)

  @@map("activity_schedules")
}

enum NotificationJobStatus {
  pending
  sent
  failed
}

model NotificationJob {
  id           String                @id @default(uuid())
  user_id      String
  activity_id  String
  type         String
  channel      String
  scheduled_at DateTime
  status       NotificationJobStatus @default(pending)
  sent_at      DateTime?
  created_at   DateTime              @default(now())

  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activity_id], references: [id], onDelete: Cascade)

  @@map("notification_jobs")
}

model NotificationPreference {
  id         String   @id @default(uuid())
  user_id    String
  type       String
  in_app     Boolean  @default(true)
  line       Boolean  @default(true)
  email      Boolean  @default(true)
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, type])
  @@map("notification_preferences")
}

model OAuthAttempt {
  id          String    @id @default(uuid())
  state_hash  String    @unique
  expires_at  DateTime
  consumed_at DateTime?
  created_at  DateTime  @default(now())

  @@index([expires_at])
  @@map("oauth_attempts")
}