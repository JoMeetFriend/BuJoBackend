generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  display_name String
  avatar_url String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  identities       UserIdentity[]
  sentRequests     Friendship[]   @relation("Requester")
  receivedRequests Friendship[]   @relation("Receiver")
  notifications    Notification[]

  @@map("users")
}

model UserIdentity {
  id               String   @id @default(uuid())
  user_id          String
  provider         String
  provider_user_id String?
  email            String?
  password_hash    String?
  created_at       DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, provider])
  @@unique([provider, provider_user_id])
  @@map("user_identities")
}

model Friendship {
  id           String   @id @default(uuid())
  requester_id String
  receiver_id  String
  status       String   @default("pending")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  requester User @relation("Requester", fields: [requester_id], references: [id], onDelete: Cascade)
  receiver  User @relation("Receiver", fields: [receiver_id], references: [id], onDelete: Cascade)

  @@unique([requester_id, receiver_id])
  @@map("friendships")
}

model Notification {
  id             String   @id @default(uuid())
  user_id        String
  type           String
  reference_id   String?
  reference_type String?
  is_read        Boolean  @default(false)
  created_at     DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notifications")
}